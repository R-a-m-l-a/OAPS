# Copy to .env.local and set your values

# Gemini API key (for AI analysis)
# GEMINI_API_KEY=your_gemini_api_key (add this env varbiable in .env.local)

# MongoDB Atlas connection string
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=OAPS (add this env varbiable in .env.local)

# JWT secret for session auth (min 32 characters; use a strong random value in production)
# JWT_SECRET=your_jwt_secret_at_least_32_characters_long (add this env varbiable in .env.local)

#Use gemini API key only for this project — please don’t share it, it’s a paid key
#its for gemini analysis
